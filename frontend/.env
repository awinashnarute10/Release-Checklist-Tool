# Committed defaults. The app talks to the real Spring Boot backend.
# (To temporarily use the in-browser mock instead, create a gitignored
#  .env.local with VITE_USE_MOCK=true — it overrides this file.)
VITE_USE_MOCK=false

# Base URL stays "/api"; Vite proxies it to the backend (see vite.config.ts),
# so there are no cross-origin/CORS issues in dev.
VITE_API_BASE_URL=/api
VITE_API_PROXY=http://localhost:8080
