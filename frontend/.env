# Committed defaults — a fresh clone runs with ZERO setup using the built-in
# localStorage mock (no backend or database needed):  npm install && npm run dev
VITE_USE_MOCK=true

# To use the real Spring Boot backend instead, create a gitignored
# frontend/.env.local with:
#   VITE_USE_MOCK=false
#   VITE_API_BASE_URL=/api          (dev: Vite proxies /api -> backend)
# For a deployed frontend, set VITE_API_BASE_URL to the backend's public URL,
# e.g. https://your-backend.onrender.com/api
VITE_API_BASE_URL=/api
VITE_API_PROXY=http://localhost:8080
