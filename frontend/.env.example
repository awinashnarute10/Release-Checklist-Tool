# Copy to .env.local to override.

# Use the built-in localStorage mock backend (default). Set to "false" to call a real API.
VITE_USE_MOCK=true

# Base URL for the real backend (used when VITE_USE_MOCK=false).
VITE_API_BASE_URL=/api

# Target for the dev proxy on /api (vite.config.ts).
VITE_API_PROXY=http://localhost:8080
