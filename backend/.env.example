# ----------------------------------------------------------------------------
# Hosted PostgreSQL connection.
# Copy this file to `.env` and fill in your provider's values.
# `.env` is gitignored — never commit real credentials.
# ----------------------------------------------------------------------------

# JDBC URL. Most managed providers require SSL — keep `sslmode=require`.
#
# Neon:      jdbc:postgresql://<endpoint>.neon.tech/<db>?sslmode=require
# Supabase:  jdbc:postgresql://<host>:5432/postgres?sslmode=require
# Railway:   jdbc:postgresql://<host>:<port>/railway?sslmode=require
SPRING_DATASOURCE_URL=jdbc:postgresql://YOUR-HOST/releasecheck?sslmode=require
SPRING_DATASOURCE_USERNAME=YOUR_DB_USER
SPRING_DATASOURCE_PASSWORD=YOUR_DB_PASSWORD

# Comma-separated origins allowed to call the API (your frontend URLs).
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Port the app listens on (Render/most PaaS inject PORT automatically).
PORT=8080
